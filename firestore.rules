rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Basispfad laut Dokumentation: /artifacts/{appId}/public/data/
    match /artifacts/{appId}/public/data/{document=**} {

      // Hilfsfunktionen
      function isAuthenticated() {
        return request.auth != null;
      }

      function getUserRole() {
        return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role;
      }

      function isAdmin() {
        return isAuthenticated() && getUserRole() == 'Admin';
      }

      function isAgency() {
        return isAuthenticated() && (getUserRole() == 'Agentur' || getUserRole() == 'Admin');
      }

      function isClient() {
        return isAuthenticated() && getUserRole() == 'Kunde';
      }
    }

    // ── Users Collection ───────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/users/{userId} {
      // Jeder authentifizierte User darf sein eigenes Profil lesen
      allow read: if request.auth != null && request.auth.uid == userId;
      // Nur Admin darf Rollen vergeben
      allow write: if request.auth != null &&
        (request.auth.uid == userId || get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role == 'Admin');
    }

    // ── Social Posts ───────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/social_posts/{postId} {
      // Agentur & Admin: vollen Zugriff
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role in ['Admin', 'Agentur'];
      // Kunde darf nur Kommentare & Status ändern (nicht title, platform, content)
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role in ['Admin', 'Agentur']
        ||
        (get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role == 'Kunde'
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'status', 'updatedAt']))
      );
    }

    // ── SEO Artikel ────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/seo_articles/{articleId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role in ['Admin', 'Agentur'];
      // Kunde darf nur Status-Feld ändern (Freigabe)
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role in ['Admin', 'Agentur']
        ||
        (get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role == 'Kunde'
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'lastModified']))
      );
    }

    // ── Kunden (Clients) ───────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/clients/{clientId} {
      // Nur Admin & Agentur dürfen Kunden sehen und verwalten
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role in ['Admin', 'Agentur'];
      allow create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.uid)).data.role in ['Admin', 'Agentur'];
    }
  }
}
