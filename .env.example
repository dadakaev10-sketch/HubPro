# Firebase Configuration
# Kopiere diese Datei zu .env und fülle deine Firebase-Projekt-Daten ein
# Firebase Konsole: https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App ID für Firestore-Pfad (/artifacts/{appId}/public/data/)
VITE_APP_ID=content-hub-pro

# Externe API-Konnektoren (Phase 3)

# WordPress REST API (Artikel direkt veröffentlichen)
# App-Passwort anlegen unter: WP-Admin → Benutzer → Profil → Anwendungspasswörter
VITE_WP_API_URL=
VITE_WP_USERNAME=
VITE_WP_APP_PASSWORD=

# Google Analytics 4
VITE_GA4_MEASUREMENT_ID=

# Google Gemini AI (KI-Artikel-Generator + Viral-Analyse)
# API-Key erstellen unter: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Meta / Facebook (zukünftig)
VITE_META_APP_ID=

# LinkedIn (zukünftig)
VITE_LINKEDIN_CLIENT_ID=
